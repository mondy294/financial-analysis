# ============ 复制为 .env 后按需修改 ============
#
# 嵌套配置用双下划线 "__" 分隔，例如：
#   QS_DATABASE__URL=sqlite:///./data_cache/quant.db
#   QS_STOCK_POOL__POOL=HS300

# 环境：dev / prod
QS_ENV=dev

# 时区
QS_TIMEZONE=Asia/Shanghai

# ---- 板块过滤（数据层不用，selector/backtest 读特征时用）----
# MAIN / MAIN,GEM / MAIN,STAR / MAIN,GEM,STAR / ALL
QS_BOARD_FILTER=MAIN

# ---- 数据库 ----
QS_DATABASE__URL=sqlite:///./data_cache/quant.db
# 生产切 PG 示例：
# QS_DATABASE__URL=postgresql+psycopg://user:pass@localhost:5432/quant

# ---- 数据源 ----
QS_DATA__CACHE_DIR=./data_cache/akshare
QS_DATA__KLINE_START_DATE=2019-01-01

# ---- 股票池 ----
# 支持 ALL / HS300 / ZZ500 / CUSTOM
# 首次验证建议 HS300（跑得快），生产建议 ALL
QS_STOCK_POOL__POOL=HS300
QS_STOCK_POOL__EXCLUDE_ST=true
QS_STOCK_POOL__EXCLUDE_NEW_LISTED_DAYS=60

# ---- 特征 ----
QS_FEATURE__VERSION=v1.0

# ---- 信号记录级别 ----
# HIT_ONLY / HIT_FILTERED / WITH_WATCH / ALL
QS_SIGNAL__RECORD_LEVEL=HIT_FILTERED

# ---- 数据质量过滤级别 ----
# OFF / ERROR / WARN_AND_ABOVE
QS_DATA_QUALITY__FILTER_LEVEL=ERROR

# ---- 日报 ----
QS_REPORT__TOP_N=20

# ---- 调度 ----
QS_SCHEDULER__DAILY_HOUR=15
QS_SCHEDULER__DAILY_MINUTE=30

# ---- 日志 ----
QS_LOGGING__LOG_DIR=./logs
QS_LOGGING__LEVEL=INFO

# ---- Provider 选择（依赖注入用）----
QS_STOCK_PROVIDER=akshare
QS_FINANCIAL_PROVIDER=akshare
