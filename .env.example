# ============ 复制为 .env 后按需修改 ============
#
# 嵌套配置用双下划线 "__" 分隔，例如：
#   QS_DATABASE__URL=sqlite:///./data_cache/quant.db
#   QS_STOCK_POOL__POOL=HS300

# 环境：dev / prod
QS_ENV=dev

# 时区
QS_TIMEZONE=Asia/Shanghai

# ---- 板块过滤（数据层不用，selector/backtest 读特征时用）----
# MAIN / MAIN,GEM / MAIN,STAR / MAIN,GEM,STAR / ALL
QS_BOARD_FILTER=MAIN

# ---- 数据库 ----
QS_DATABASE__URL=sqlite:///./data_cache/quant.db
# 生产切 PG 示例：
# QS_DATABASE__URL=postgresql+psycopg://user:pass@localhost:5432/quant

# ---- 数据源 ----
QS_DATA__CACHE_DIR=./data_cache/akshare
QS_DATA__KLINE_START_DATE=2019-01-01
# 拉取并发线程数（1 = 关闭并发）
QS_DATA__CONCURRENCY=4
# 节流模式：true=全局节流（保守）；false=每线程节流（真并发，默认）
QS_DATA__THROTTLE_GLOBAL=false
# 拉数据阶段的板块过滤（独立于 QS_BOARD_FILTER）
# MAIN / MAIN,GEM / MAIN,STAR / MAIN,GEM,STAR / ALL；默认只拉主板
QS_DATA__FETCH_BOARDS=MAIN

# ---- 股票池 ----
# 支持 ALL / HS300 / ZZ500 / CUSTOM
# 首次验证建议 HS300（跑得快），生产建议 ALL
QS_STOCK_POOL__POOL=HS300
QS_STOCK_POOL__EXCLUDE_ST=true
QS_STOCK_POOL__EXCLUDE_NEW_LISTED_DAYS=60

# ---- 特征 ----
QS_FEATURE__VERSION=v1.0

# ---- 信号记录级别 ----
# HIT_ONLY / HIT_FILTERED / WITH_WATCH / ALL
QS_SIGNAL__RECORD_LEVEL=HIT_FILTERED

# ---- 数据质量过滤级别 ----
# OFF / ERROR / WARN_AND_ABOVE
QS_DATA_QUALITY__FILTER_LEVEL=ERROR

# ---- 日报 ----
QS_REPORT__TOP_N=20

# ---- 调度 ----
QS_SCHEDULER__DAILY_HOUR=15
QS_SCHEDULER__DAILY_MINUTE=30

# ---- 日志 ----
QS_LOGGING__LOG_DIR=./logs
QS_LOGGING__LEVEL=INFO

# ---- Provider 选择（依赖注入用）----
QS_STOCK_PROVIDER=akshare
QS_FINANCIAL_PROVIDER=akshare

# ---- AI 分析（DeepSeek，OpenAI 兼容）----
# 默认关闭；设 ENABLED=true 且填 API_KEY 后，报告阶段为每只 Top 股票生成建议
QS_AI__ENABLED=false
QS_AI__PROVIDER=deepseek
QS_AI__BASE_URL=https://api.deepseek.com
QS_AI__API_KEY=
QS_AI__MODEL=deepseek-v4-pro
QS_AI__CONCURRENCY=5
QS_AI__TIMEOUT_SEC=120
# thinking 模型：reasoning 也占额度，太小会导致正文为空，给足预算
QS_AI__MAX_TOKENS=3000
# deepseek-v4-pro 特有：low / medium / high
QS_AI__REASONING_EFFORT=high
QS_AI__THINKING_ENABLED=true

# ============ 策略 v2（阶段 A 分层门控，均为默认值，按需微调）============

# ---- L2 硬风险否决（命中任一直接淘汰）----
QS_HARD_FILTER__RSI_MAX=85.0
QS_HARD_FILTER__RETURN_5D_MAIN=20.0
QS_HARD_FILTER__RETURN_5D_GEM=30.0
QS_HARD_FILTER__RETURN_5D_STAR=30.0
QS_HARD_FILTER__RETURN_5D_BSE=30.0
QS_HARD_FILTER__DIVERGENCE_VOL_MIN=0.8
QS_HARD_FILTER__ONE_WORD_LIMIT_RATIO=0.98
QS_HARD_FILTER__REQUIRE_MA20=true
QS_HARD_FILTER__REQUIRE_MACD=true
QS_HARD_FILTER__REQUIRE_RSI14=true

# ---- L4 共振门控（不同大类命中数 = 共振度）----
QS_RESONANCE__BULL_STRONG_MIN=1
QS_RESONANCE__BULL_WEAK_MIN=2
QS_RESONANCE__BEAR_WEAK_MIN=2
QS_RESONANCE__BEAR_STRONG_MIN=3
QS_RESONANCE__UNKNOWN_MIN=1
QS_RESONANCE__BEAR_WEAK_REQUIRE_FUNDAMENTAL=true
QS_RESONANCE__BEAR_STRONG_REQUIRE_FUNDAMENTAL=true
QS_RESONANCE__ENABLED_CATEGORIES=trend,reversal,volume_price,fundamental

# ---- L5 软风险扣分（未到硬淘汰线但值得警惕）----
QS_SOFT_PENALTY__RSI_75_85=5.0
QS_SOFT_PENALTY__RSI_WARN_LOWER=75.0
QS_SOFT_PENALTY__RETURN_5D_UPPER=3.0
QS_SOFT_PENALTY__RETURN_5D_WARN_MAIN=15.0
QS_SOFT_PENALTY__RETURN_5D_WARN_GEM=20.0
QS_SOFT_PENALTY__RETURN_5D_WARN_STAR=20.0
QS_SOFT_PENALTY__RETURN_5D_WARN_BSE=20.0
QS_SOFT_PENALTY__DQ_WARN=2.0
QS_SOFT_PENALTY__BOLL_WIDTH_HIGH=3.0
QS_SOFT_PENALTY__BOLL_WIDTH_THRESHOLD=15.0
QS_SOFT_PENALTY__ATR_HIGH=5.0
QS_SOFT_PENALTY__ATR_RATIO_THRESHOLD=0.08
